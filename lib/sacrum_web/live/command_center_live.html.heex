<Layouts.app flash={@flash} current_user={@current_user}>
  <div class="text-center">
    <h1 class="text-4xl font-bold">
      Welcome, {@current_user.name || @current_user.email}
    </h1>
    <p class="text-text-secondary mt-4">
      Command Center coming soon...
    </p>
  </div>
</Layouts.app>
